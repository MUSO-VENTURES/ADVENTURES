# Copy to .env and fill in, or set these as Supabase Edge Function secrets
# (see README). Never commit a real .env file.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never ship to a client

# Email (used to notify the next venue's owner/manager)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM="MUSO Adventures <hello@yourdomain.com>"

# SMS (optional — only needed if a venue_contacts row uses notify_by = 'sms' or 'both')
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
